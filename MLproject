name: pytorch-bsf
conda_env: environment.yml
entry_points:
  main:
    parameters:
      params: {type: path}
      values: {type: path}
      meshgrid: {type: path, default: "."}
      degree: {type: int}
      smoothness_weight: {type: float, default: 0.0}
    command: >-
      python -m torch_bsf
      --params={params}
      --values={values}
      --meshgrid={meshgrid}
      --degree={degree}
      --smoothness_weight={smoothness_weight}
  kfold:
    parameters:
      params: {type: path}
      values: {type: path}
      meshgrid: {type: path, default: "."}
      degree: {type: int}
      smoothness_weight: {type: float, default: 0.0}
    command: >-
      python -m torch_bsf.model_selection.kfold
      --params={params}
      --values={values}
      --meshgrid={meshgrid}
      --degree={degree}
      --smoothness_weight={smoothness_weight}
  degree_selection:
    parameters:
      params: {type: path}
      values: {type: path}
      min_degree: {type: int, default: 1}
      max_degree: {type: int, default: 5}
      num_folds: {type: int, default: 5}
      max_epochs: {type: int, default: 2}
      header: {type: int, default: 0}
      accelerator: {type: str, default: "auto"}
      devices: {type: str, default: "auto"}
    command: >-
      python -m torch_bsf.model_selection.degree_selection
      --params={params}
      --values={values}
      --min_degree={min_degree}
      --max_degree={max_degree}
      --num_folds={num_folds}
      --max_epochs={max_epochs}
      --header={header}
      --accelerator={accelerator}
      --devices={devices}
  elastic_net_grid:
    parameters:
      n_lambdas: {type: int}
      n_alphas: {type: int}
      n_vertex_copies: {type: int}
      base: {type: int}
    command: >-
      python -m torch_bsf.model_selection.elastic_net_grid > weight_{n_lambdas}_{n_alphas}_{n_vertex_copies}_{base}.csv
      --n_lambdas={n_lambdas}
      --n_alphas={n_alphas}
      --n_vertex_copies={n_vertex_copies}
      --base={base}
